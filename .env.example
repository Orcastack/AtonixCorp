# Root environment for Docker Compose interpolation and hybrid AI secrets.
# Container-level Django settings still also read ./api/.env through docker-compose env_file.

FRONTEND_BASE_URL=http://localhost:3000
APPROVAL_NOTIFICATION_BASE_URL=http://localhost:3000

# Brevo SMTP email delivery. Put the actual SMTP key only in the untracked .env.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=b2acdf001@smtp-brevo.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@atonixcorp.com
ORGANIZATION_EMAIL_DOMAIN=atonixcorp.com

# Backend security
DJANGO_SECRET_KEY=change-me-in-production
BANKING_TOKEN_ENCRYPTION_KEY=replace-with-a-strong-random-secret

# Hybrid AI / Claude integration
AI_ENABLE_EXTERNAL_MODELS=0
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE_URL=https://api.anthropic.com
CLAUDE_OPUS_MODEL=claude-opus-4-1
CLAUDE_SONNET_MODEL=claude-sonnet-4-0
AI_DEFAULT_MAX_TOKENS=2000

# Optional local registry credentials. Keep real values only in your untracked .env.
DOCKER_USER_NAME=
DOCKER_PASSWORD=

# Optional GitHub credentials. Keep real values only in your untracked .env.
GITHUB_USER_NAME=
GITHUB_TOKEN=