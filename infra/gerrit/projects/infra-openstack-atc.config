[access "refs/*"]
    read = group Registered Users

[access "refs/heads/*"]
    # No direct pushes to any branch. All changes must go through Gerrit review.
    push = deny group Registered Users

[access "refs/for/refs/heads/*"]
    # All engineers can submit patchsets for review.
    push = group Registered Users

[access "refs/heads/main"]
    # Only Gerrit (submit action) and infra leads may land commits.
    submit = group Infra Leads
    submit = group Gerrit Service Account

    # DEV and TEST environment changes: minimum 1 infra engineer approval
    label-Code-Review = -2..+2 group Infra Engineers
    label-Verified    = -1..+1 group Jenkins Service Account

[access "refs/heads/release/*"]
    # STAGE and PROD releases require infra lead + Ledgora owner approval.
    submit = group Infra Leads
    label-Code-Review = -2..+2 group Infra Leads
    label-Code-Review = -2..+2 group Ledgora Owners
    label-Verified    = -1..+1 group Jenkins Service Account

[submit]
    # A change cannot be merged unless Jenkins votes Verified +1
    # and at least one Code-Review +2 is present.
    action = merge if necessary

[label "Verified"]
    function     = MaxWithBlock
    value         = -1 Fails
    value         =  0 No score
    value         =  1 Verified

[label "Code-Review"]
    function     = MaxWithBlock
    copyCondition = changekind:TRIVIAL_REBASE
    value         = -2 This shall not be merged
    value         = -1 I would prefer this is not merged as is
    value         =  0 No score
    value         =  1 Looks good to me, but someone else must also approve
    value         =  2 Looks good to me, approved

[project]
    description = Ledgora OpenStack Infrastructure as Code
    requireChangeId = true
    requireSignedOffBy = false
    rejectImplicitMerges = true

[receive]
    requireContributorAgreement = false
    maxObjectSizeLimit = 10m
